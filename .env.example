# Open Studio

# MiniMax API Configuration
# Copy this file to .env.local and fill in your values

# Your MiniMax API Key (required)
MINIMAX_API_KEY=

# Key type: pay_as_you_go or token_plan
MINIMAX_API_KEY_TYPE=pay_as_you_go

# Base URL for MiniMax API
MINIMAX_BASE_URL=https://api.minimax.io

# Text models
MINIMAX_TEXT_MODEL=MiniMax-M2.7
MINIMAX_TEXT_MODEL_FAST=MiniMax-M2.7-highspeed

# Image model
MINIMAX_IMAGE_MODEL=image-01

# Music model
MINIMAX_MUSIC_MODEL=music-2.6

# Video model (optional - video generation may not be available yet)
MINIMAX_VIDEO_MODEL=

# Provider mode: official-text-v2, openai-compatible, or anthropic-compatible
MINIMAX_PROVIDER_MODE=official-text-v2

# Enable demo mode (uses mock data, no API key needed)
NEXT_PUBLIC_DEMO_MODE=false

# Enable debug mode (detailed logs)
MINIMAX_DEBUG_MODE=false

# Local storage driver: json (default)
LOCAL_STORAGE_DRIVER=json
