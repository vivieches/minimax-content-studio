# Open Studio

# MiniMax API Configuration
# Copy this file to .env.local and fill in your values

# Your MiniMax API Key (required)
MINIMAX_API_KEY=

# Key type: pay_as_you_go or token_plan
MINIMAX_API_KEY_TYPE=pay_as_you_go

# Base URL for MiniMax API
MINIMAX_BASE_URL=https://api.minimax.io

# Text models
MINIMAX_TEXT_MODEL=MiniMax-M2.7
MINIMAX_TEXT_MODEL_FAST=MiniMax-M2.7-highspeed

# Image model
MINIMAX_IMAGE_MODEL=image-01

# Music model
MINIMAX_MUSIC_MODEL=music-2.6

# Video model (optional - video generation may not be available yet)
MINIMAX_VIDEO_MODEL=

# Provider mode: official-text-v2, openai-compatible, or anthropic-compatible
MINIMAX_PROVIDER_MODE=official-text-v2

# Enable demo mode (uses mock data, no API key needed)
NEXT_PUBLIC_DEMO_MODE=false

# Enable debug mode (detailed logs)
MINIMAX_DEBUG_MODE=false

# OpenAI-compatible providers
# Non-MiniMax model choices are configured in Settings.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1

TOGETHER_API_KEY=
TOGETHER_BASE_URL=https://api.together.xyz/v1

# Native text providers
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com

GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# Native media providers
FAL_KEY=
FAL_BASE_URL=https://queue.fal.run

REPLICATE_API_TOKEN=
REPLICATE_BASE_URL=https://api.replicate.com

ELEVENLABS_API_KEY=
ELEVENLABS_BASE_URL=https://api.elevenlabs.io

# Local storage driver: json (default)
LOCAL_STORAGE_DRIVER=json
